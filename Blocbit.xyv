      }}>
        <div style={{ fontSize: 13, color: COLORS.textMuted, marginBottom: 6 }}>Total Portfolio Value</div>
        <div className="mono" style={{ fontSize: 34, fontWeight: 800, color: COLORS.gold }}>{fmtFCFA(user.balance)}</div>
        <div style={{ display: "flex", gap: 20, marginTop: 16 }}>
          {[
            { label: "BLB Token", value: `${user.tokens} BLB` },
            { label: "Referral Earned", value: "7,500 FCFA" },
            { label: "Mining (Active)", value: "Gold Plan" },
          ].map(i => (
            <div key={i.label}>
              <div style={{ fontSize: 11, color: COLORS.textMuted }}>{i.label}</div>
              <div className="mono" style={{ fontSize: 13, fontWeight: 600, color: COLORS.text }}>{i.value}</div>
            </div>
          ))}
        </div>
        <div style={{ display: "flex", gap: 10, marginTop: 18 }}>
          <button className="btn-gold" style={{ flex: 1, padding: 10, borderRadius: 8, fontSize: 14 }} onClick={() => setPage("wallet")}>Deposit</button>
          <button className="btn-outline" style={{ flex: 1, padding: 10, borderRadius: 8, fontSize: 14 }} onClick={() => setPage("wallet")}>Withdraw</button>
        </div>
      </div>

      {/* Stats */}
      <div className="grid-2" style={{ marginBottom: 20 }}>
        <StatCard label="Active Investment" value="10,000 FCFA" sub="Pool Alpha · 12% APY" icon="📈" />
        <StatCard label="Daily Earnings" value="~33 FCFA" sub="Est. based on pool" icon="💰" color={COLORS.green} />
        <StatCard label="BLB Mining" icon="⛏️"
          value={<MiningCounter ratePerSec={activePlan.ratePerSec} startTime={miningStart} />}
          sub="Gold Plan · Live"
        />
        <StatCard label="Referrals" value="12 users" sub="+7,500 FCFA earned" icon="👥" color="#7B68EE" />
      </div>

      {/* Recent Transactions */}
      <div style={{ background: COLORS.bgCard, border: `1px solid ${COLORS.border}`, borderRadius: 14, padding: 18 }}>
        <div style={{ fontWeight: 700, marginBottom: 14, fontSize: 15 }}>Recent Transactions</div>
        {MOCK_TXS.map(tx => (
          <div key={tx.id} style={{
            display: "flex", justifyContent: "space-between", alignItems: "center",
            padding: "10px 0", borderBottom: `1px solid ${COLORS.border}`,
          }}>
            <div style={{ display: "flex", gap: 12, alignItems: "center" }}>
              <div style={{
                width: 36, height: 36, borderRadius: "50%",
                background: COLORS.bgCard2, display: "flex", alignItems: "center", justifyContent: "center", fontSize: 16,
              }}>
                {tx.type === "deposit" ? "⬇️" : tx.type === "withdrawal" ? "⬆️" : tx.type === "mining" ? "⛏️" : tx.type === "referral" ? "👥" : "📈"}
              </div>
              <div>
                <div style={{ fontSize: 14, fontWeight: 600, textTransform: "capitalize" }}>{tx.type}</div>
                <div style={{ fontSize: 12, color: COLORS.textMuted }}>{tx.date}</div>
              </div>
            </div>
            <div style={{ textAlign: "right" }}>
              <div className="mono" style={{
                fontSize: 14, fontWeight: 700,
                color: tx.amount.startsWith("+") ? COLORS.green : COLORS.red,
              }}>{tx.amount}</div>
              <span className={`badge ${tx.status === "completed" ? "badge-green" : "badge-gold"}`}>{tx.status}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  );
}

function WalletPage({ user, toast }) {
  const [tab, setTab] = useState("deposit");
  const [amount, setAmount] = useState("");
  const [method, setMethod] = useState("airtel");

  const handleSubmit = () => {
    if (!amount || isNaN(amount)) return toast("Please enter a valid amount");
    const n = Number(amount);
    if (tab === "withdraw") {
      if (n < 10000) return toast("Minimum withdrawal is 10,000 FCFA");
      if (n > 500000) return toast("Maximum withdrawal is 500,000 FCFA");
    }
    toast(`${tab === "deposit" ? "Deposit" : "Withdrawal"} of ${fmtFCFA(n)} initiated ✓`);
    setAmount("");
  };

  return (
    <div className="fade-in" style={{ padding: "20px 16px 80px" }}>
      <h2 style={{ fontSize: 22, fontWeight: 800, marginBottom: 20 }}>Wallet</h2>

      {/* Balance */}
      <div style={{
        background: COLORS.bgCard, border: `1px solid ${COLORS.border}`,
        borderRadius: 16, padding: 20, marginBottom: 20,
      }}>
        <div style={{ fontSize: 13, color: COLORS.textMuted }}>Available Balance</div>
        <div className="mono" style={{ fontSize: 30, fontWeight: 800, color: COLORS.gold, margin: "6px 0" }}>{fmtFCFA(user.balance)}</div>
        <div style={{ fontSize: 13, color: COLORS.textMuted }}>{user.tokens} BLB Tokens</div>
      </div>

      {/* Withdrawal rules */}
      <div style={{ background: "rgba(252,213,53,0.06)", border: `1px solid rgba(252,213,53,0.2)`, borderRadius: 12, padding: 14, marginBottom: 20 }}>
        <div style={{ fontSize: 13, fontWeight: 600, color: COLORS.gold, marginBottom: 6 }}>⚠️ Withdrawal Rules</div>
        <div style={{ fontSize: 12, color: COLORS.textMuted, lineHeight: 1.7 }}>
          • Min: 10,000 FCFA — Max: 500,000 FCFA<br />
          • Maximum 2 withdrawals per month<br />
          • Investment stops immediately after withdrawal
        </div>
      </div>

      {/* Tabs */}
      <div style={{ display: "flex", gap: 4, background: COLORS.bgCard2, borderRadius: 10, padding: 4, marginBottom: 20 }}>
        {["deposit", "withdraw"].map(t => (
          <button key={t} onClick={() => setTab(t)} style={{
            flex: 1, padding: "10px", borderRadius: 8, border: "none", cursor: "pointer",
            background: tab === t ? COLORS.gold : "transparent",
            color: tab === t ? "#0B0E11" : COLORS.textMuted,
            fontWeight: 700, fontSize: 14, fontFamily: "'Space Grotesk', sans-serif",
            transition: "all 0.2s", textTransform: "capitalize",
          }}>{t}</button>
        ))}
      </div>

      {/* Payment method */}
      <div style={{ marginBottom: 16 }}>
        <div style={{ fontSize: 13, color: COLORS.textMuted, marginBottom: 8, fontWeight: 500 }}>Payment Method</div>
        <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: 8 }}>
          {[
            { id: "airtel", label: "Airtel Money", icon: "📱" },
            { id: "moov",   label: "Moov Money",   icon: "📲" },
            { id: "card",   label: "Visa / MC",    icon: "💳" },
          ].map(m => (
            <div key={m.id} onClick={() => setMethod(m.id)} style={{
              border: `1px solid ${method === m.id ? COLORS.gold : COLORS.border}`,
              borderRadius: 10, padding: "12px 8px", textAlign: "center",
              cursor: "pointer", background: method === m.id ? "rgba(252,213,53,0.07)" : COLORS.bgCard,
              transition: "all 0.2s",
            }}>
              <div style={{ fontSize: 20 }}>{m.icon}</div>
              <div style={{ fontSize: 11, marginTop: 4, color: method === m.id ? COLORS.gold : COLORS.textMuted }}>{m.label}</div>
            </div>
          ))}
        </div>
      </div>

      {/* Amount */}
      <div style={{ marginBottom: 16 }}>
        <div style={{ fontSize: 13, color: COLORS.textMuted, marginBottom: 8 }}>Amount (FCFA)</div>
        <input
          className="inp mono"
          placeholder="e.g. 25000"
          value={amount}
          onChange={e => setAmount(e.target.value)}
          style={{ padding: "14px 16px", borderRadius: 10, fontSize: 16 }}
        />
      </div>

      <button className="btn-gold" style={{ width: "100%", padding: 14, borderRadius: 10, fontSize: 16 }} onClick={handleSubmit}>
        {tab === "deposit" ? "Deposit Funds" : "Request Withdrawal"}
      </button>

      {/* TX History */}
      <div style={{ marginTop: 28 }}>
        <div style={{ fontWeight: 700, marginBottom: 14, fontSize: 15 }}>Transaction History</div>
        {MOCK_TXS.map(tx => (
          <div key={tx.id} style={{
            display: "flex", justifyContent: "space-between",
            padding: "12px 0", borderBottom: `1px solid ${COLORS.border}`,
          }}>
            <div>
              <div style={{ fontSize: 14, fontWeight: 600, textTransform: "capitalize" }}>{tx.type}</div>
              <div style={{ fontSize: 12, color: COLORS.textMuted }}>{tx.date}</div>
            </div>
            <div style={{ textAlign: "right" }}>
              <div className="mono" style={{ fontWeight: 700, color: tx.amount.startsWith("+") ? COLORS.green : COLORS.red }}>{tx.amount}</div>
              <span className={`badge ${tx.status === "completed" ? "badge-green" : "badge-gold"}`}>{tx.status}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  );
}

function MiningPage({ user, toast }) {
  const [activeMining, setActiveMining] = useState({ planId: 5, startTime: Date.now() - 86400 * 3 * 1000 });
  const [selected, setSelected] = useState(null);
  const activePlan = MINING_PLANS.find(p => p.id === activeMining?.planId);
  const daysLeft = activeMining ? Math.max(0, 30 - ((Date.now() - activeMining.startTime) / (86400 * 1000))) : 0;

  return (
    <div className="fade-in" style={{ padding: "20px 16px 80px" }}>
      <h2 style={{ fontSize: 22, fontWeight: 800, marginBottom: 6 }}>⛏️ BLB Mining</h2>
      <p style={{ color: COLORS.textMuted, fontSize: 13, marginBottom: 20 }}>Mine Blocbit tokens 24/7. Rewards vary by network conditions.</p>

      {/* Active mining */}
      {activeMining && activePlan && (
        <div className="glow-gold" style={{
          background: "linear-gradient(135deg, #1a1600 0%, #1E2329 100%)",
          border: `1px solid ${COLORS.gold}40`,
          borderRadius: 16, padding: 20, marginBottom: 24,
        }}>
          <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start", marginBottom: 12 }}>
            <div>
              <div style={{ fontSize: 13, color: COLORS.textMuted }}>Active Plan</div>
              <div style={{ fontSize: 18, fontWeight: 800, color: COLORS.gold }}>{activePlan.label} — ${activePlan.price}</div>
            </div>
            <span className="badge badge-green pulse">● MINING</span>
          </div>
          <div style={{ fontSize: 12, color: COLORS.textMuted, marginBottom: 4 }}>Total Mined</div>
          <MiningCounter ratePerSec={activePlan.ratePerSec} startTime={activeMining.startTime} />
          <div className="progress-bar" style={{ height: 6, marginTop: 14, marginBottom: 6 }}>
            <div className="progress-fill" style={{ width: `${((30 - daysLeft) / 30) * 100}%` }} />
          </div>
          <div style={{ fontSize: 12, color: COLORS.textMuted }}>{fmt(daysLeft, 1)} days remaining · Total reward: {activePlan.totalReward} BLB</div>
        </div>
      )}

      {/* Plans */}
      <div style={{ fontWeight: 700, marginBottom: 14, fontSize: 15 }}>All Mining Plans</div>
      <div className="grid-2">
        {MINING_PLANS.map(plan => {
          const isActive = activeMining?.planId === plan.id;
          return (
            <div key={plan.id} className={`plan-card ${plan.popular ? "popular" : ""}`}
              onClick={() => setSelected(plan)}
              style={{ borderColor: isActive ? COLORS.green : plan.popular ? COLORS.gold : COLORS.border }}>
              {plan.popular && (
                <div style={{
                  position: "absolute", top: -10, right: 12,
                  background: "linear-gradient(135deg, #FCD535, #F0A500)",
                  color: "#0B0E11", fontSize: 10, fontWeight: 800,
                  padding: "2px 10px", borderRadius: 99,
                }}>⭐ POPULAR</div>
              )}
              {isActive && (
                <div style={{
                  position: "absolute", top: -10, left: 12,
                  background: COLORS.green, color: "#0B0E11", fontSize: 10, fontWeight: 800,
                  padding: "2px 10px", borderRadius: 99,
                }}>● ACTIVE</div>
              )}
              <div style={{ display: "flex", justifyContent: "space-between", marginBottom: 8 }}>
                <span style={{ fontWeight: 800, fontSize: 16, color: plan.color }}>${plan.price}</span>
                <span style={{ fontSize: 12, color: COLORS.textMuted }}>{plan.label}</span>
              </div>
              <div style={{ fontSize: 11, color: COLORS.textMuted, lineHeight: 1.7 }}>
                <div>Total: <span className="mono" style={{ color: COLORS.text }}>{plan.totalReward} BLB</span></div>
                <div>Duration: <span style={{ color: COLORS.text }}>30 days</span></div>
              </div>
              <button className="btn-gold" style={{
                width: "100%", marginTop: 10, padding: "8px", borderRadius: 7, fontSize: 13,
                opacity: isActive ? 0.4 : 1,
              }} onClick={e => { e.stopPropagation(); if (!isActive) toast(`${plan.label} plan selected. Complete payment to start mining.`); }}>
                {isActive ? "Active" : "Start Mining"}
              </button>
            </div>
          );
        })}
      </div>

      {/* Plan detail modal */}
      {selected && (
        <div className="modal-bg" onClick={() => setSelected(null)}>
          <div className="modal-box" onClick={e => e.stopPropagation()}>
            <div style={{ fontWeight: 800, fontSize: 20, marginBottom: 4 }}>{selected.label} Plan</div>
            <div style={{ color: COLORS.gold, fontSize: 28, fontWeight: 800, marginBottom: 16 }}>${selected.price}</div>
            <div style={{ background: COLORS.bgCard2, borderRadius: 10, padding: 16, marginBottom: 16 }}>
              {[
                ["Duration", "30 days"],
                ["Total Reward", `${selected.totalReward} BLB`],
                ["Rate/second", `${selected.ratePerSec.toFixed(20)} BLB`],
                ["Status", "Variable (network-dependent)"],
              ].map(([k, v]) => (
                <div key={k} style={{ display: "flex", justifyContent: "space-between", padding: "8px 0", borderBottom: `1px solid ${COLORS.border}` }}>
                  <span style={{ color: COLORS.textMuted, fontSize: 13 }}>{k}</span>
                  <span className="mono" style={{ fontSize: 13 }}>{v}</span>
                </div>
              ))}
            </div>
            <p style={{ fontSize: 12, color: COLORS.textMuted, marginBottom: 16, lineHeight: 1.6 }}>
              ⚠️ Mining rewards are variable and non-guaranteed. Actual earnings depend on network conditions and BLB token price at time of payout.
            </p>
            <button className="btn-gold" style={{ width: "100%", padding: 14, borderRadius: 10, fontSize: 15 }}
              onClick={() => { toast(`${selected.label} plan activated! Mining starts after payment.`); setSelected(null); }}>
              Activate — ${selected.price}
            </button>
            <button className="btn-outline" style={{ width: "100%", padding: 12, borderRadius: 10, fontSize: 14, marginTop: 10 }}
              onClick={() => setSelected(null)}>Cancel</button>
          </div>
        </div>
      )}
    </div>
  );
}

function TasksPage({ toast }) {
  const [tasks, setTasks] = useState(TASKS);
  const referralLink = "https://blocbit.io/ref/BLB-A7X92";

  const complete = (id) => {
    setTasks(prev => prev.map(t => t.id === id ? { ...t, done: true } : t));
    const task = tasks.find(t => t.id === id);
    toast(`Task complete! Earned ${task.reward} ✓`);
  };

  return (
    <div className="fade-in" style={{ padding: "20px 16px 80px" }}>
      <h2 style={{ fontSize: 22, fontWeight: 800, marginBottom: 6 }}>🎯 Tasks & Rewards</h2>
      <p style={{ color: COLORS.textMuted, fontSize: 13, marginBottom: 20 }}>Complete tasks to earn FCFA and BLB tokens.</p>

      {/* Tasks */}
      {tasks.map(task => (
        <div key={task.id} style={{
          background: COLORS.bgCard, border: `1px solid ${task.done ? COLORS.green + "40" : COLORS.border}`,
          borderRadius: 14, padding: 18, marginBottom: 12,
          display: "flex", justifyContent: "space-between", alignItems: "center",
        }}>
          <div style={{ display: "flex", gap: 14, alignItems: "center" }}>
            <div style={{ fontSize: 28 }}>{task.icon}</div>
            <div>
              <div style={{ fontWeight: 600, fontSize: 15 }}>{task.title}</div>
              <div style={{ color: COLORS.gold, fontSize: 13, marginTop: 2 }}>+{task.reward}</div>
            </div>
          </div>
          {task.done
            ? <span className="badge badge-green">✓ Done</span>
            : <button className="btn-gold" style={{ padding: "8px 18px", borderRadius: 8, fontSize: 13 }} onClick={() => complete(task.id)}>Claim</button>
          }
        </div>
      ))}

      {/* Referral */}
      <div style={{
        background: COLORS.bgCard, border: `1px solid ${COLORS.border}`,
        borderRadius: 14, padding: 20, marginTop: 24,
      }}>
        <div style={{ fontWeight: 700, fontSize: 16, marginBottom: 4 }}>👥 Referral Program</div>
        <p style={{ color: COLORS.textMuted, fontSize: 13, marginBottom: 16 }}>Invite friends and earn commission on every referral investment.</p>
        <div style={{ background: COLORS.bgCard2, borderRadius: 10, padding: 14, marginBottom: 14 }}>
          <div style={{ fontSize: 12, color: COLORS.textMuted, marginBottom: 4 }}>Your referral link</div>
          <div className="mono" style={{ fontSize: 13, color: COLORS.gold, wordBreak: "break-all" }}>{referralLink}</div>
        </div>
        <div className="grid-2">
          <div style={{ textAlign: "center", background: COLORS.bgCard2, borderRadius: 10, padding: 14 }}>
            <div style={{ fontSize: 22, fontWeight: 800, color: COLORS.gold }}>12</div>
            <div style={{ fontSize: 12, color: COLORS.textMuted }}>Total Referrals</div>
          </div>
          <div style={{ textAlign: "center", background: COLORS.bgCard2, borderRadius: 10, padding: 14 }}>
            <div className="mono" style={{ fontSize: 18, fontWeight: 800, color: COLORS.green }}>7,500 FCFA</div>
            <div style={{ fontSize: 12, color: COLORS.textMuted }}>Total Earned</div>
          </div>
        </div>
        <button className="btn-gold" style={{ width: "100%", marginTop: 14, padding: 12, borderRadius: 10, fontSize: 14 }}
          onClick={() => { navigator.clipboard?.writeText(referralLink); toast("Referral link copied! ✓"); }}>
          📋 Copy Referral Link
        </button>
      </div>
    </div>
  );
}

function SupportPage() {
  const [messages, setMessages] = useState([
    { from: "bot", text: "👋 Hello! I'm the Blocbit support assistant. How can I help you today?" },
  ]);
  const [input, setInput] = useState("");
  const bottomRef = useRef(null);

  const faqs = [
    "How do I deposit?",
    "Withdrawal rules",
    "Mining plans",
    "Referral commission",
  ];

  const send = (text) => {
    const msg = text || input.trim();
    if (!msg) return;
    const newMsgs = [...messages, { from: "user", text: msg }];
    setMessages(newMsgs);
    setInput("");
    setTimeout(() => {
      const replies = {
        "How do I deposit?": "Go to Wallet → Deposit. We support Airtel Money, Moov Money, Visa, and Mastercard. Minimum deposit is 5,000 FCFA.",
        "Withdrawal rules": "Min: 10,000 FCFA · Max: 500,000 FCFA · Max 2 per month. Note: active investments stop on withdrawal.",
        "Mining plans": "We offer 12 mining plans from $5 to $1,000. Each runs 30 days and generates BLB tokens continuously.",
        "Referral commission": "You earn a commission % on every investment made by your referrals. Check your referral stats in the Tasks tab.",
      };
      setMessages(prev => [...prev, { from: "bot", text: replies[msg] || "Thanks for your message! Our support team will respond within 24h. You can also email support@blocbit.io." }]);
    }, 800);
  };

  useEffect(() => { bottomRef.current?.scrollIntoView({ behavior: "smooth" }); }, [messages]);

  return (
    <div className="fade-in" style={{ padding: "20px 16px 80px" }}>
      <h2 style={{ fontSize: 22, fontWeight: 800, marginBottom: 20 }}>💬 Support</h2>

      {/* FAQ shortcuts */}
      <div style={{ marginBottom: 16, display: "flex", flexWrap: "wrap", gap: 8 }}>
        {faqs.map(q => (
          <button key={q} className="btn-outline" style={{ padding: "6px 14px", borderRadius: 99, fontSize: 12 }} onClick={() => send(q)}>{q}</button>
        ))}
      </div>

      {/* Chat */}
      <div style={{
        background: COLORS.bgCard, border: `1px solid ${COLORS.border}`,
        borderRadius: 14, padding: 16, minHeight: 320,
        maxHeight: "50vh", overflowY: "auto", marginBottom: 14,
        display: "flex", flexDirection: "column", gap: 12,
      }}>
        {messages.map((m, i) => (
          <div key={i} style={{ display: "flex", justifyContent: m.from === "user" ? "flex-end" : "flex-start" }}>
            <div className={`chat-bubble ${m.from === "user" ? "bubble-user" : "bubble-bot"}`}>{m.text}</div>
          </div>
        ))}
        <div ref={bottomRef} />
      </div>

      <div style={{ display: "flex", gap: 10 }}>
        <input
          className="inp"
          placeholder="Type a message…"
          value={input}
          onChange={e => setInput(e.target.value)}
          onKeyDown={e => e.key === "Enter" && send()}
          style={{ padding: "12px 16px", borderRadius: 10, fontSize: 14 }}
        />
        <button className="btn-gold" style={{ padding: "12px 18px", borderRadius: 10, fontSize: 16, flexShrink: 0 }} onClick={() => send()}>➤</button>
      </div>
    </div>
  );
}

function AdminPage({ toast }) {
  const [tab, setTab] = useState("users");

  const mockUsers = [
    { id: 1, name: "Adam Doe",     email: "adam@mail.com",   balance: 125000, status: "active",   joined: "2026-01-10" },
    { id: 2, name: "Mariam A.",    email: "mariam@mail.com", balance: 47000,  status: "active",   joined: "2026-02-03" },
    { id: 3, name: "Ibrahim K.",   email: "ibra@mail.com",   balance: 230000, status: "suspended",joined: "2026-01-28" },
    { id: 4, name: "Fatima N.",    email: "fatima@mail.com", balance: 15000,  status: "active",   joined: "2026-03-05" },
  ];

  return (
    <div className="fade-in" style={{ padding: "20px 16px 80px" }}>
      <div style={{ display: "flex", alignItems: "center", gap: 10, marginBottom: 20 }}>
        <span style={{ fontSize: 22 }}>🔐</span>
        <div>
          <h2 style={{ fontSize: 20, fontWeight: 800 }}>Admin Panel</h2>
          <div style={{ fontSize: 12, color: COLORS.textMuted }}>Platform Management</div>
        </div>
      </div>

      {/* Stats */}
      <div className="grid-2" style={{ marginBottom: 20 }}>
        <StatCard label="Total Users"    value="14,200" sub="+120 this week"   icon="👥" />
        <StatCard label="Total Invested" value="2.4B FCFA" sub="Across 3 pools" icon="📈" color={COLORS.green} />
        <StatCard label="Active Miners"  value="3,421"  sub="12 plan types"   icon="⛏️" />
        <StatCard label="Pending Withdrawals" value="42" sub="Review required" icon="⬆️" color={COLORS.red} />
      </div>

      {/* Tab nav */}
