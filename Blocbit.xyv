          <div style={{ fontSize: 22, fontWeight: 800 }}>{user.name} 👋</div>
        </div>
        <div style={{ textAlign: "right" }}>
          <div style={{ fontSize: 11, color: COLORS.textMuted }}>Referral code</div>
