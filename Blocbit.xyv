// ─── UTILS ────────────────────────────────────────────────────────────────────
const fmt = (n, d = 2) => Number(n).toFixed(d);
const fmtFCFA = (n) => Number(n).toLocaleString("fr-FR") + " FCFA";

// ─── STYLES ──────────────────────────────────────────────────────────────────
const css = `
  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap');

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0B0E11;
    --bgCard: #161A1E;
    --bgCard2: #1E2329;
    --border: #2B3139;
    --gold: #FCD535;
    --goldDim: #B8960C;
    --green: #0ECB81;
    --red: #F6465D;
    --text: #EAECEF;
    --muted: #848E9C;
    --dim: #5E6673;
  }

  body { background: var(--bg); color: var(--text); font-family: 'Space Grotesk', sans-serif; }

  .mono { font-family: 'JetBrains Mono', monospace; }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 4px; height: 4px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  /* Ticker */
  @keyframes ticker {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .ticker-track { animation: ticker 30s linear infinite; display: flex; }
  .ticker-wrap { overflow: hidden; }

  /* Pulse */
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.5} }
  .pulse { animation: pulse 2s ease-in-out infinite; }

  /* Mining counter */
  @keyframes countUp { from { opacity:0; transform:translateY(4px); } to { opacity:1; transform:translateY(0); } }
  .count-anim { animation: countUp 0.3s ease; }

  /* Glow */
  @keyframes glow {
    0%,100% { box-shadow: 0 0 12px rgba(252,213,53,0.15); }
    50%      { box-shadow: 0 0 28px rgba(252,213,53,0.40); }
  }
  .glow-gold { animation: glow 3s ease-in-out infinite; }

  /* Fade in */
  @keyframes fadeIn { from{opacity:0;transform:translateY(12px)} to{opacity:1;transform:translateY(0)} }
  .fade-in { animation: fadeIn 0.4s ease forwards; }

  /* Spinner */
  @keyframes spin { to { transform: rotate(360deg); } }
  .spin { animation: spin 1s linear infinite; }

  /* Mining bar fill */
  @keyframes barFill { from{width:0} to{width:var(--w)} }

  /* Hover card */
  .card-hover { transition: transform 0.2s, border-color 0.2s; }
  .card-hover:hover { transform: translateY(-2px); border-color: var(--gold) !important; }

  /* Button */
  .btn-gold {
    background: linear-gradient(135deg, #FCD535 0%, #F0A500 100%);
    color: #0B0E11;
    font-weight: 700;
    border: none;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.15s;
    font-family: 'Space Grotesk', sans-serif;
  }
  .btn-gold:hover { opacity: 0.9; transform: scale(1.01); }
  .btn-gold:active { transform: scale(0.98); }

  .btn-outline {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text);
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
    font-family: 'Space Grotesk', sans-serif;
  }
  .btn-outline:hover { border-color: var(--gold); background: rgba(252,213,53,0.05); }

  /* Input */
  .inp {
    background: var(--bgCard2);
    border: 1px solid var(--border);
    color: var(--text);
    font-family: 'Space Grotesk', sans-serif;
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
  }
  .inp:focus { border-color: var(--gold); }
  .inp::placeholder { color: var(--dim); }

  /* Progress bar */
  .progress-bar {
    background: var(--border);
    border-radius: 99px;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    border-radius: 99px;
    background: linear-gradient(90deg, #FCD535, #F0A500);
    transition: width 1s ease;
  }

  /* Nav */
  .nav-item {
    cursor: pointer;
    padding: 6px 12px;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 500;
    transition: background 0.2s, color 0.2s;
    color: var(--muted);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
  }
  .nav-item.active { color: var(--gold); }
  .nav-item:hover { color: var(--text); }

  /* Status badge */
  .badge {
    padding: 2px 8px;
    border-radius: 99px;
    font-size: 11px;
    font-weight: 600;
  }
  .badge-green { background: rgba(14,203,129,0.15); color: #0ECB81; }
  .badge-gold  { background: rgba(252,213,53,0.15);  color: #FCD535; }
  .badge-red   { background: rgba(246,70,93,0.15);   color: #F6465D; }
  .badge-blue  { background: rgba(74,144,226,0.15);  color: #4A90E2; }

  /* Toast */
  @keyframes toastIn  { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }
  @keyframes toastOut { from{opacity:1} to{opacity:0} }
  .toast { animation: toastIn 0.3s ease; }

  /* Mobile bottom nav */
  .bottom-nav {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    background: var(--bgCard);
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-around;
    padding: 8px 0 12px;
    z-index: 100;
  }

  /* Desktop top nav */
  .top-nav {
    background: var(--bgCard);
    border-bottom: 1px solid var(--border);
    position: sticky; top: 0; z-index: 99;
  }

  /* Grid helpers */
  .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; }

  @media(max-width:640px) {
    .grid-3 { grid-template-columns: 1fr 1fr; }
    .hide-mobile { display: none !important; }
  }
  @media(min-width:641px) {
    .hide-desktop { display: none !important; }
  }

  /* Modal */
  .modal-bg {
    position: fixed; inset:0;
    background: rgba(0,0,0,0.75);
    display: flex; align-items: center; justify-content: center;
    z-index: 200;
    padding: 16px;
  }
  .modal-box {
    background: var(--bgCard);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 28px;
    width: 100%; max-width: 440px;
    max-height: 90vh;
    overflow-y: auto;
  }

  /* Plan card */
  .plan-card {
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 16px;
    background: var(--bgCard2);
    position: relative;
    cursor: pointer;
    transition: all 0.2s;
  }
  .plan-card:hover { border-color: var(--gold); transform: translateY(-2px); }
  .plan-card.popular { border-color: var(--gold); }

  /* Dropdown */
  .dropdown {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    background: var(--bgCard);
    border: 1px solid var(--border);
    border-radius: 10px;
    min-width: 180px;
    z-index: 200;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  }
  .dropdown-item {
    padding: 12px 16px;
    cursor: pointer;
    font-size: 14px;
    transition: background 0.15s;
    display: flex; align-items: center; gap: 10px;
  }
  .dropdown-item:hover { background: var(--bgCard2); }

  /* Separator */
  .sep { border: none; border-top: 1px solid var(--border); margin: 12px 0; }

  /* Support chat bubble */
  .chat-bubble {
    padding: 10px 14px;
    border-radius: 12px;
    max-width: 80%;
    font-size: 14px;
    line-height: 1.5;
  }
  .bubble-user { background: rgba(252,213,53,0.15); border: 1px solid rgba(252,213,53,0.3); margin-left: auto; }
  .bubble-bot  { background: var(--bgCard2); border: 1px solid var(--border); }
`;

// ─── COMPONENTS ──────────────────────────────────────────────────────────────

function Toast({ msg, onDone }) {
  useEffect(() => { const t = setTimeout(onDone, 2800); return () => clearTimeout(t); }, []);
  return (
    <div className="toast" style={{
      position: "fixed", bottom: 80, left: "50%", transform: "translateX(-50%)",
      background: COLORS.bgCard2, border: `1px solid ${COLORS.border}`,
      borderRadius: 10, padding: "12px 20px", fontSize: 14, zIndex: 300,
      boxShadow: "0 8px 32px rgba(0,0,0,0.5)", whiteSpace: "nowrap",
      color: COLORS.text, display: "flex", alignItems: "center", gap: 8,
    }}>
      <span style={{ color: COLORS.gold }}>✦</span> {msg}
    </div>
  );
}

function Ticker() {
  const items = [...CRYPTO_PRICES, ...CRYPTO_PRICES];
  return (
    <div className="ticker-wrap" style={{ background: COLORS.bgCard2, borderBottom: `1px solid ${COLORS.border}`, padding: "7px 0", overflow: "hidden" }}>
      <div className="ticker-track" style={{ width: "max-content", display: "flex", gap: 0 }}>
        {items.map((c, i) => (
          <span key={i} style={{ display: "inline-flex", alignItems: "center", gap: 6, padding: "0 24px", fontSize: 13, borderRight: `1px solid ${COLORS.border}` }}>
            <span style={{ color: COLORS.gold, fontWeight: 700 }}>{c.symbol}</span>
            <span className="mono" style={{ color: COLORS.text }}>${c.price}</span>
            <span style={{ color: c.change.startsWith("+") ? COLORS.green : COLORS.red }}>{c.change}</span>
          </span>
        ))}
      </div>
    </div>
  );
}

function StatCard({ label, value, sub, icon, color = COLORS.gold }) {
  return (
    <div className="card-hover fade-in" style={{
      background: COLORS.bgCard, border: `1px solid ${COLORS.border}`,
      borderRadius: 14, padding: "18px 20px",
    }}>
      <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start" }}>
        <div>
          <div style={{ color: COLORS.textMuted, fontSize: 12, fontWeight: 500, marginBottom: 6, textTransform: "uppercase", letterSpacing: "0.05em" }}>{label}</div>
          <div className="mono" style={{ fontSize: 20, fontWeight: 700, color: COLORS.text }}>{value}</div>
          {sub && <div style={{ color: COLORS.textMuted, fontSize: 12, marginTop: 4 }}>{sub}</div>}
        </div>
        <div style={{ fontSize: 22, background: `${color}18`, borderRadius: 10, padding: "8px 10px" }}>{icon}</div>
      </div>
    </div>
  );
}

function PoolCard({ pool }) {
  const pct = (pool.current / pool.capacity) * 100;
  const remaining = pool.capacity - pool.current;
  const full = pct >= 100;
  return (
    <div className="card-hover" style={{
      background: COLORS.bgCard, border: `1px solid ${full ? COLORS.red : COLORS.border}`,
      borderRadius: 14, padding: 20,
    }}>
      <div style={{ display: "flex", justifyContent: "space-between", marginBottom: 10 }}>
        <div>
          <div style={{ fontWeight: 700, fontSize: 15 }}>{pool.name}</div>
          <span className="badge badge-gold" style={{ marginTop: 4, display: "inline-block" }}>APY {pool.apy}</span>
        </div>
        {full && <span className="badge badge-red">FULL</span>}
      </div>
      <div className="progress-bar" style={{ height: 8, marginBottom: 10 }}>
        <div className="progress-fill" style={{ width: `${Math.min(pct, 100)}%` }} />
      </div>
      <div style={{ display: "flex", justifyContent: "space-between", fontSize: 13, color: COLORS.textMuted }}>
        <span>{fmtFCFA(pool.current)} filled</span>
        <span>{fmtFCFA(remaining)} left</span>
      </div>
      <div style={{ fontSize: 12, color: COLORS.textDim, marginTop: 4 }}>Capacity: {fmtFCFA(pool.capacity)}</div>
      <button
        className="btn-gold"
        disabled={full}
        style={{ width: "100%", padding: "10px", borderRadius: 8, marginTop: 14, fontSize: 14, opacity: full ? 0.4 : 1 }}
      >
        {full ? "Pool Full" : "Invest Now"}
      </button>
    </div>
  );
}

function MiningCounter({ ratePerSec, startTime }) {
  const [tokens, setTokens] = useState(0);
  const rafRef = useRef(null);

  useEffect(() => {
    const tick = () => {
      const elapsed = (Date.now() - startTime) / 1000;
      setTokens(ratePerSec * elapsed);
      rafRef.current = requestAnimationFrame(tick);
    };
    rafRef.current = requestAnimationFrame(tick);
    return () => cancelAnimationFrame(rafRef.current);
  }, [ratePerSec, startTime]);

  return (
    <span className="mono" style={{ color: COLORS.gold, fontSize: 15, fontWeight: 600 }}>
      {tokens.toFixed(14)} BLB
    </span>
  );
}

