            fontWeight: 700, fontSize: 12, fontFamily: "'Space Grotesk', sans-serif",
            textTransform: "capitalize", transition: "all 0.2s",
          }}>{t}</button>
        ))}
      </div>

      {/* Users */}
      {tab === "users" && (
        <div style={{ background: COLORS.bgCard, border: `1px solid ${COLORS.border}`, borderRadius: 14, overflow: "hidden" }}>
          {mockUsers.map((u, i) => (
            <div key={u.id} style={{
              display: "flex", justifyContent: "space-between", alignItems: "center",
              padding: "14px 18px", borderBottom: i < mockUsers.length - 1 ? `1px solid ${COLORS.border}` : "none",
            }}>
              <div>
                <div style={{ fontWeight: 600, fontSize: 14 }}>{u.name}</div>
                <div style={{ fontSize: 12, color: COLORS.textMuted }}>{u.email} · {u.joined}</div>
              </div>
              <div style={{ display: "flex", alignItems: "center", gap: 10 }}>
                <span className="mono" style={{ fontSize: 13, color: COLORS.gold }}>{fmtFCFA(u.balance)}</span>
                <span className={`badge ${u.status === "active" ? "badge-green" : "badge-red"}`}>{u.status}</span>
                <button className="btn-outline" style={{ padding: "4px 10px", borderRadius: 6, fontSize: 11 }}
                  onClick={() => toast(`Action taken on ${u.name}`)}>
                  {u.status === "active" ? "Suspend" : "Restore"}
                </button>
              </div>
            </div>
          ))}
        </div>
      )}

      {/* Pools */}
      {tab === "pools" && (
        <div className="grid-3">
          {POOLS.map(p => <PoolCard key={p.id} pool={p} />)}
        </div>
      )}

      {/* Transactions */}
      {tab === "transactions" && (
        <div style={{ background: COLORS.bgCard, border: `1px solid ${COLORS.border}`, borderRadius: 14, overflow: "hidden" }}>
          {MOCK_TXS.map((tx, i) => (
            <div key={tx.id} style={{
              display: "flex", justifyContent: "space-between", alignItems: "center",
              padding: "14px 18px", borderBottom: i < MOCK_TXS.length - 1 ? `1px solid ${COLORS.border}` : "none",
            }}>
              <div>
                <div style={{ fontWeight: 600, textTransform: "capitalize" }}>{tx.type}</div>
                <div style={{ fontSize: 12, color: COLORS.textMuted }}>{tx.date}</div>
              </div>
              <div style={{ textAlign: "right" }}>
                <div className="mono" style={{ color: tx.amount.startsWith("+") ? COLORS.green : COLORS.red }}>{tx.amount}</div>
                <span className={`badge ${tx.status === "completed" ? "badge-green" : "badge-gold"}`}>{tx.status}</span>
              </div>
            </div>
          ))}
        </div>
      )}

      {/* Mining */}
      {tab === "mining" && (
        <div className="grid-2">
          {MINING_PLANS.map(p => (
            <div key={p.id} style={{
              background: COLORS.bgCard, border: `1px solid ${COLORS.border}`,
              borderRadius: 12, padding: 16,
            }}>
              <div style={{ display: "flex", justifyContent: "space-between" }}>
                <span style={{ fontWeight: 700, color: p.color }}>{p.label}</span>
                <span className="mono" style={{ color: COLORS.gold }}>${p.price}</span>
              </div>
              <div style={{ fontSize: 12, color: COLORS.textMuted, marginTop: 8 }}>
                Active miners: <span style={{ color: COLORS.text }}>{Math.floor(Math.random() * 400 + 50)}</span>
              </div>
              <div style={{ fontSize: 12, color: COLORS.textMuted }}>
                Total reward: <span className="mono" style={{ color: COLORS.text }}>{p.totalReward} BLB</span>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  );
}

// ─── AUTH MODAL ──────────────────────────────────────────────────────────────

function AuthModal({ mode, onClose, onLogin, toast }) {
  const [tab, setTab] = useState(mode);
  const [form, setForm] = useState({ name: "", email: "", password: "", code: "" });
  const [step, setStep] = useState(1); // 1=form, 2=OTP

  const handleSubmit = () => {
    if (!form.email || !form.password) return toast("Please fill in all fields");
    if (tab === "register" && !form.name) return toast("Name is required");
    if (step === 1 && tab === "register") { setStep(2); toast("OTP sent to your email"); return; }
    toast(tab === "login" ? "Welcome back! 🎉" : "Account created! Welcome to Blocbit 🎉");
    onLogin({ name: form.name || "User", email: form.email, balance: 0, tokens: "0.00000", code: "A7X92" });
    onClose();
  };

  return (
    <div className="modal-bg" onClick={onClose}>
      <div className="modal-box" onClick={e => e.stopPropagation()}>
        {/* Logo */}
        <div style={{ textAlign: "center", marginBottom: 24 }}>
          <div style={{ fontSize: 28, fontWeight: 900, letterSpacing: "-0.03em" }}>
            <span style={{ color: COLORS.gold }}>Bloc</span><span style={{ color: COLORS.text }}>bit</span>
          </div>
        </div>

        {/* Tabs */}
        <div style={{ display: "flex", gap: 4, background: COLORS.bgCard2, borderRadius: 10, padding: 4, marginBottom: 24 }}>
          {["login", "register"].map(t => (
            <button key={t} onClick={() => { setTab(t); setStep(1); }} style={{
              flex: 1, padding: 10, borderRadius: 8, border: "none", cursor: "pointer",
              background: tab === t ? COLORS.gold : "transparent",
              color: tab === t ? "#0B0E11" : COLORS.textMuted,
              fontWeight: 700, fontSize: 14, fontFamily: "'Space Grotesk', sans-serif",
              textTransform: "capitalize", transition: "all 0.2s",
            }}>{t}</button>
          ))}
        </div>

        {step === 1 ? (
          <>
            {tab === "register" && (
              <div style={{ marginBottom: 14 }}>
                <label style={{ fontSize: 13, color: COLORS.textMuted, display: "block", marginBottom: 6 }}>Full Name</label>
                <input className="inp" placeholder="Your name" value={form.name}
                  onChange={e => setForm({ ...form, name: e.target.value })}
                  style={{ padding: "12px 14px", borderRadius: 10 }} />
              </div>
            )}
            <div style={{ marginBottom: 14 }}>
              <label style={{ fontSize: 13, color: COLORS.textMuted, display: "block", marginBottom: 6 }}>Email</label>
              <input className="inp" placeholder="your@email.com" type="email" value={form.email}
                onChange={e => setForm({ ...form, email: e.target.value })}
                style={{ padding: "12px 14px", borderRadius: 10 }} />
            </div>
            <div style={{ marginBottom: tab === "register" ? 14 : 20 }}>
              <label style={{ fontSize: 13, color: COLORS.textMuted, display: "block", marginBottom: 6 }}>Password</label>
              <input className="inp" placeholder="••••••••" type="password" value={form.password}
                onChange={e => setForm({ ...form, password: e.target.value })}
                style={{ padding: "12px 14px", borderRadius: 10 }} />
            </div>
            {tab === "register" && (
              <div style={{ marginBottom: 20 }}>
                <label style={{ fontSize: 13, color: COLORS.textMuted, display: "block", marginBottom: 6 }}>Referral Code (optional)</label>
                <input className="inp" placeholder="e.g. BLB-A7X92" value={form.code}
                  onChange={e => setForm({ ...form, code: e.target.value })}
                  style={{ padding: "12px 14px", borderRadius: 10 }} />
              </div>
            )}
          </>
        ) : (
          <div style={{ marginBottom: 20 }}>
            <div style={{ textAlign: "center", marginBottom: 16, color: COLORS.textMuted, fontSize: 14 }}>
              Enter the 6-digit OTP sent to <span style={{ color: COLORS.gold }}>{form.email}</span>
            </div>
            <input className="inp mono" placeholder="000000" maxLength={6}
              style={{ padding: "16px 14px", borderRadius: 10, fontSize: 24, textAlign: "center", letterSpacing: "0.4em" }} />
          </div>
        )}

        <button className="btn-gold" style={{ width: "100%", padding: 14, borderRadius: 10, fontSize: 16 }} onClick={handleSubmit}>
          {tab === "login" ? "Sign In" : step === 1 ? "Continue →" : "Verify & Register"}
        </button>

        {tab === "register" && (
          <div style={{ marginTop: 14, background: "rgba(252,213,53,0.06)", border: `1px solid rgba(252,213,53,0.2)`, borderRadius: 10, padding: 12 }}>
            <div style={{ fontSize: 12, color: COLORS.textMuted, display: "flex", alignItems: "center", gap: 6 }}>
              <span>🤖</span> Optional: Enable AI facial verification for enhanced security after registration.
            </div>
          </div>
        )}

        <button style={{ width: "100%", background: "none", border: "none", color: COLORS.textMuted, cursor: "pointer", marginTop: 14, fontSize: 14 }} onClick={onClose}>
          Cancel
        </button>
      </div>
    </div>
  );
}

// ─── APP ─────────────────────────────────────────────────────────────────────

export default function Blocbit() {
  const [page, setPage] = useState("home");
  const [user, setUser] = useState(null);
  const [authModal, setAuthModal] = useState(null);
  const [dropdown, setDropdown] = useState(false);
  const [toastMsg, setToastMsg] = useState(null);
  const dropRef = useRef(null);

  const toast = (msg) => setToastMsg(msg);

  const isLoggedIn = !!user;

  // Demo user
  const loginDemo = () => setUser({ name: "Adam", email: "adam@blocbit.io", balance: 125000, tokens: "0.00082140", code: "A7X92" });

  const logout = () => { setUser(null); setPage("home"); setDropdown(false); };

  const navItems = [
    { id: "home",      label: "Home",    icon: "🏠" },
    { id: "dashboard", label: "Account", icon: "📊" },
    { id: "wallet",    label: "Wallet",  icon: "💳" },
    { id: "mining",    label: "Mining",  icon: "⛏️" },
    { id: "tasks",     label: "Tasks",   icon: "🎯" },
    { id: "support",   label: "Support", icon: "💬" },
  ];

  const handleNavClick = (id) => {
    if (["dashboard", "wallet"].includes(id) && !isLoggedIn) {
      setAuthModal("login");
      return;
    }
    setPage(id);
  };

  useEffect(() => {
    const close = (e) => { if (!dropRef.current?.contains(e.target)) setDropdown(false); };
    document.addEventListener("mousedown", close);
    return () => document.removeEventListener("mousedown", close);
  }, []);

  const renderPage = () => {
    switch (page) {
      case "home":      return <HomePage setPage={handleNavClick} isLoggedIn={isLoggedIn} />;
      case "dashboard": return isLoggedIn ? <DashboardPage user={user} setPage={setPage} /> : <HomePage setPage={handleNavClick} isLoggedIn={false} />;
      case "wallet":    return isLoggedIn ? <WalletPage user={user} toast={toast} /> : <HomePage setPage={handleNavClick} isLoggedIn={false} />;
      case "mining":    return <MiningPage user={user} toast={toast} />;
      case "tasks":     return <TasksPage toast={toast} />;
      case "support":   return <SupportPage />;
      case "admin":     return <AdminPage toast={toast} />;
      default:          return <HomePage setPage={handleNavClick} isLoggedIn={isLoggedIn} />;
    }
  };

  return (
    <>
      <style>{css}</style>
      <div style={{ minHeight: "100vh", background: COLORS.bg, paddingBottom: 60 }}>

        {/* Top Nav */}
        <nav className="top-nav">
          <div style={{ maxWidth: 900, margin: "0 auto", padding: "0 16px", display: "flex", alignItems: "center", justifyContent: "space-between", height: 58 }}>
            {/* Logo */}
            <div style={{ fontWeight: 900, fontSize: 22, letterSpacing: "-0.03em", cursor: "pointer" }} onClick={() => setPage("home")}>
              <span style={{ color: COLORS.gold }}>Bloc</span><span style={{ color: COLORS.text }}>bit</span>
            </div>

            {/* Desktop nav */}
            <div className="hide-mobile" style={{ display: "flex", gap: 4 }}>
              {navItems.map(n => (
                <button key={n.id} onClick={() => handleNavClick(n.id)} style={{
                  background: "none", border: "none", cursor: "pointer",
                  padding: "6px 14px", borderRadius: 8, fontSize: 14, fontWeight: 500,
                  color: page === n.id ? COLORS.gold : COLORS.textMuted,
                  fontFamily: "'Space Grotesk', sans-serif", transition: "color 0.2s",
                }}>{n.label}</button>
              ))}
            </div>

            {/* Right: 3-dot menu + admin */}
            <div style={{ display: "flex", gap: 8, alignItems: "center" }}>
              {isLoggedIn && (
                <button className="btn-outline hide-mobile" style={{ padding: "6px 14px", borderRadius: 8, fontSize: 12 }}
                  onClick={() => setPage("admin")}>⚙️ Admin</button>
              )}
              <div ref={dropRef} style={{ position: "relative" }}>
                <button onClick={() => setDropdown(d => !d)} style={{
                  background: COLORS.bgCard2, border: `1px solid ${COLORS.border}`,
                  borderRadius: 8, padding: "8px 12px", cursor: "pointer", color: COLORS.text, fontSize: 18,
                }}>⋮</button>
                {dropdown && (
                  <div className="dropdown">
                    {isLoggedIn ? (
                      <>
                        <div style={{ padding: "12px 16px", borderBottom: `1px solid ${COLORS.border}` }}>
                          <div style={{ fontSize: 13, fontWeight: 600 }}>{user.name}</div>
                          <div style={{ fontSize: 11, color: COLORS.textMuted }}>{user.email}</div>
                        </div>
                        <div className="dropdown-item" onClick={() => { setPage("dashboard"); setDropdown(false); }}>📊 Dashboard</div>
                        <div className="dropdown-item" onClick={() => { setPage("admin"); setDropdown(false); }}>🔐 Admin Panel</div>
                        <div className="dropdown-item" style={{ color: COLORS.red }} onClick={logout}>🚪 Logout</div>
                      </>
                    ) : (
                      <>
                        <div className="dropdown-item" onClick={() => { setAuthModal("login"); setDropdown(false); }}>🔑 Login</div>
                        <div className="dropdown-item" onClick={() => { setAuthModal("register"); setDropdown(false); }}>✨ Register</div>
                        <div className="dropdown-item" style={{ color: COLORS.gold, fontSize: 12 }} onClick={() => { loginDemo(); setDropdown(false); toast("Demo mode activated!"); }}>⚡ Try Demo</div>
                      </>
                    )}
                  </div>
                )}
              </div>
            </div>
          </div>
        </nav>

        {/* Ticker */}
        <Ticker />

        {/* Content */}
        <div style={{ maxWidth: 900, margin: "0 auto" }}>
          {renderPage()}
        </div>

        {/* Mobile bottom nav */}
        <nav className="bottom-nav hide-desktop">
          {navItems.map(n => (
            <button key={n.id} className={`nav-item ${page === n.id ? "active" : ""}`}
              onClick={() => handleNavClick(n.id)}
              style={{ background: "none", border: "none" }}>
              <span style={{ fontSize: 20 }}>{n.icon}</span>
              <span style={{ fontSize: 10 }}>{n.label}</span>
            </button>
          ))}
        </nav>

        {/* Auth modal */}
        {authModal && (
          <AuthModal
            mode={authModal}
            onClose={() => setAuthModal(null)}
            onLogin={(u) => { setUser(u); setPage("dashboard"); }}
            toast={toast}
          />
        )}

        {/* Toast */}
        {toastMsg && <Toast msg={toastMsg} onDone={() => setToastMsg(null)} />}
      </div>
    </>
  );
}
