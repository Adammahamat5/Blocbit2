function DashboardPage({ user, setPage }) {
  const miningStart = useRef(Date.now() - 86400 * 3 * 1000).current;
  const activePlan = MINING_PLANS[4]; // Gold plan

  return (
    <div className="fade-in" style={{ padding: "20px 16px 80px" }}>
